{
  "name": "millennium-capital-simul",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "vinext build",
    "build:flutter-web": "node scripts/build-flutter-web.mjs",
    "build:release": "node scripts/build-flutter-web.mjs && vinext build",
    "start": "vinext start",
    "test": "vinext build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern build --ignore-pattern .next --ignore-pattern .vinext --ignore-pattern .wrangler --ignore-pattern public/play --ignore-pattern flutter_app/.dart_tool --ignore-pattern flutter_app/build --ignore-pattern flutter_app/.plugin_symlinks",
    "db:generate": "drizzle-kit generate",
    "data:fetch": "node scripts/fetch-market-data.mjs",
    "data:fetch:krx-full": "python scripts/fetch-krx-full-market.py",
    "dev:sites": "vinext dev"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
